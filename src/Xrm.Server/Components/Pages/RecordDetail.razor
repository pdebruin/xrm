@page "/records/{EntityId:guid}/new"
@page "/records/{EntityId:guid}/{RecordId:guid}"
@using System.Text.Json
@using Xrm.Server.Models
@using Xrm.Server.Services
@inject IEntityService EntityService
@inject IRecordService RecordService
@inject IRelationshipService RelationshipService
@inject NavigationManager Nav
@rendermode InteractiveServer

<PageTitle>XRM</PageTitle>

@if (_error is not null)
{
    <div class="alert alert-danger">@_error</div>
}

@if (_entityDef is null)
{
    <p>Loading...</p>
}
else
{
    <div class="detail-header">
        <button class="btn btn-link" @onclick="GoBack">← Back to @(_entityDef.PluralName ?? _entityDef.DisplayName)</button>
        <h3>@(_isNew ? "New" : "Edit") @(_entityDef.DisplayName ?? _entityDef.Name)</h3>
    </div>

    <div class="detail-form">
        @foreach (var field in _fields)
        {
            <div class="mb-3">
                <label class="form-label">
                    @(field.DisplayName ?? field.Name)
                    @if (field.IsRequired) { <span class="text-danger">*</span> }
                </label>
                @switch (field.DataType)
                {
                    case FieldDataType.Boolean:
                        <div class="form-check">
                            <input type="checkbox" class="form-check-input" 
                                   checked="@GetBoolValue(field.Name)"
                                   @onchange="(e) => SetValue(field.Name, e.Value)" />
                        </div>
                        break;

                    case FieldDataType.Choice:
                        <select class="form-select" value="@GetValue(field.Name)" 
                                @onchange="(e) => SetValue(field.Name, e.Value)">
                            <option value="">-- Select --</option>
                            @foreach (var opt in GetOptions(field))
                            {
                                <option value="@opt">@opt</option>
                            }
                        </select>
                        break;

                    case FieldDataType.RichText:
                        <textarea class="form-control" rows="4" 
                                  value="@GetValue(field.Name)"
                                  @onchange="(e) => SetValue(field.Name, e.Value)"></textarea>
                        break;

                    case FieldDataType.Number:
                    case FieldDataType.Decimal:
                        <input type="number" class="form-control" 
                               step="@(field.DataType == FieldDataType.Decimal ? "0.01" : "1")"
                               value="@GetValue(field.Name)"
                               @onchange="(e) => SetValue(field.Name, e.Value)" />
                        break;

                    case FieldDataType.Date:
                        <input type="date" class="form-control"
                               value="@GetValue(field.Name)"
                               @onchange="(e) => SetValue(field.Name, e.Value)" />
                        break;

                    case FieldDataType.DateTime:
                        <input type="datetime-local" class="form-control"
                               value="@GetValue(field.Name)"
                               @onchange="(e) => SetValue(field.Name, e.Value)" />
                        break;

                    default:
                        <input type="@GetInputType(field.DataType)" class="form-control"
                               maxlength="@(field.MaxLength?.ToString() ?? "")"
                               value="@GetValue(field.Name)"
                               @onchange="(e) => SetValue(field.Name, e.Value)" />
                        break;
                }
            </div>
        }

        @* Parent relationships as dropdowns with navigation *@
        @foreach (var rel in _parentRelationships)
        {
            <div class="mb-3">
                <label class="form-label">@(rel.DisplayName ?? rel.Name)</label>
                <div class="d-flex gap-2">
                    <select class="form-select" value="@GetParentValue(rel.Id)" 
                            @onchange="(e) => SetParentValue(rel.Id, e.Value?.ToString())">
                        <option value="">-- None --</option>
                        @if (_parentOptions.TryGetValue(rel.Id, out var options))
                        {
                            @foreach (var opt in options)
                            {
                                <option value="@opt.Id">@opt.Label</option>
                            }
                        }
                    </select>
                    @if (Guid.TryParse(GetParentValue(rel.Id), out _))
                    {
                        <button class="btn btn-outline-secondary btn-sm" title="Go to parent"
                                @onclick="() => NavigateToParent(rel)">↗</button>
                    }
                </div>
            </div>
        }

        <div class="detail-actions">
            <button class="btn btn-primary" @onclick="Save" disabled="@_saving">
                @(_saving ? "Saving..." : "Save")
            </button>
            <button class="btn btn-outline-secondary" @onclick="GoBack">Cancel</button>
        </div>
    </div>

    @* Child relationships — full grid with CRUD *@
    @if (!_isNew && _childRelationships.Any())
    {
        <hr />
        @foreach (var rel in _childRelationships)
        {
            var section = _childSections.GetValueOrDefault(rel.Id);
            if (section is null) continue;

            <div class="child-section mb-4">
                <div class="d-flex justify-content-between align-items-center mb-2">
                    <h5 class="mb-0">@(section.Entity.PluralName ?? section.Entity.DisplayName ?? section.Entity.Name)</h5>
                    <button class="btn btn-sm btn-primary" @onclick="() => StartAddChild(rel.Id)">+ Add</button>
                </div>

                @if (section.Records.Any())
                {
                    <div class="table-responsive">
                        <table class="table table-sm table-hover">
                            <thead>
                                <tr>
                                    @foreach (var f in section.Fields)
                                    {
                                        <th>@(f.DisplayName ?? f.Name)</th>
                                    }
                                    <th style="width:100px;"></th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var rec in section.Records)
                                {
                                    <tr>
                                        @foreach (var f in section.Fields)
                                        {
                                            <td>@GetChildCellValue(rec.DataJson, f.Name)</td>
                                        }
                                        <td class="text-end text-nowrap">
                                            <button class="btn btn-sm btn-outline-primary me-1" title="Edit"
                                                    @onclick="() => StartEditChild(rel.Id, rec)">✎</button>
                                            <button class="btn btn-sm btn-outline-danger" title="Delete"
                                                    @onclick="() => DeleteChild(rel.Id, rec.Id)">✕</button>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <p class="text-muted">No records yet.</p>
                }

                @* Inline add/edit form *@
                @if (_editingChildRelId == rel.Id)
                {
                    <div class="card card-body bg-light mt-2">
                        <h6>@(_editingChildId is null ? "Add" : "Edit") @(section.Entity.DisplayName ?? section.Entity.Name)</h6>
                        @foreach (var f in section.Fields)
                        {
                            <div class="mb-2">
                                <label class="form-label form-label-sm">@(f.DisplayName ?? f.Name)</label>
                                @switch (f.DataType)
                                {
                                    case FieldDataType.Boolean:
                                        <div class="form-check">
                                            <input type="checkbox" class="form-check-input"
                                                   checked="@GetChildEditBool(f.Name)"
                                                   @onchange="(e) => SetChildEditValue(f.Name, e.Value)" />
                                        </div>
                                        break;

                                    case FieldDataType.Number:
                                    case FieldDataType.Decimal:
                                        <input type="number" class="form-control form-control-sm"
                                               step="@(f.DataType == FieldDataType.Decimal ? "0.01" : "1")"
                                               value="@GetChildEditValue(f.Name)"
                                               @onchange="(e) => SetChildEditValue(f.Name, e.Value)" />
                                        break;

                                    case FieldDataType.Choice:
                                        <select class="form-select form-select-sm" value="@GetChildEditValue(f.Name)"
                                                @onchange="(e) => SetChildEditValue(f.Name, e.Value)">
                                            <option value="">-- Select --</option>
                                            @foreach (var opt in GetOptions(f))
                                            {
                                                <option value="@opt">@opt</option>
                                            }
                                        </select>
                                        break;

                                    default:
                                        <input type="text" class="form-control form-control-sm"
                                               value="@GetChildEditValue(f.Name)"
                                               @onchange="(e) => SetChildEditValue(f.Name, e.Value)" />
                                        break;
                                }
                            </div>
                        }
                        <div class="mt-2">
                            <button class="btn btn-sm btn-primary me-1" @onclick="() => SaveChild(rel.Id)">Save</button>
                            <button class="btn btn-sm btn-outline-secondary" @onclick="CancelChildEdit">Cancel</button>
                        </div>
                        @if (_childEditError is not null)
                        {
                            <div class="alert alert-danger mt-2 py-1 px-2 small">@_childEditError</div>
                        }
                    </div>
                }
            </div>
        }
    }
}

@code {
    [Parameter] public Guid EntityId { get; set; }
    [Parameter] public Guid? RecordId { get; set; }

    private bool _isNew => RecordId is null;
    private bool _saving;
    private string? _error;
    private EntityDefinition? _entityDef;
    private List<FieldDefinition> _fields = new();
    private Dictionary<string, object?> _data = new();

    private List<RelationshipDefinition> _parentRelationships = new();
    private List<RelationshipDefinition> _childRelationships = new();
    private Dictionary<Guid, List<ParentOption>> _parentOptions = new();
    private Dictionary<Guid, string?> _parentValues = new();
    private Dictionary<Guid, string?> _originalParentValues = new();
    private Dictionary<Guid, Guid?> _parentLinkIds = new();
    private Dictionary<Guid, ChildSection> _childSections = new();

    // Child inline editing state
    private Guid? _editingChildRelId;
    private Guid? _editingChildId;
    private Dictionary<string, object?> _childEditData = new();
    private string? _childEditError;

    protected override async Task OnParametersSetAsync()
    {
        _error = null;
        _entityDef = await EntityService.GetByIdAsync(EntityId);
        _fields = _entityDef?.Fields?.OrderBy(f => f.SortOrder).ToList() ?? new();

        // Get relationships for this entity
        var (sourceRels, targetRels) = await RelationshipService.GetForEntityAsync(EntityId);
        _parentRelationships = targetRels.Where(r => r.RelationshipType == RelationshipType.OneToMany).ToList();
        _childRelationships = sourceRels.Where(r => r.RelationshipType == RelationshipType.OneToMany).ToList();

        // Load parent options
        foreach (var rel in _parentRelationships)
        {
            var parentEntity = await EntityService.GetByIdAsync(rel.SourceEntityId);
            var displayField = parentEntity?.Fields?.OrderBy(f => f.SortOrder).FirstOrDefault()?.Name ?? "Name";
            var parentRecords = await RecordService.GetAllAsync(rel.SourceEntityId, 1, 100);

            _parentOptions[rel.Id] = parentRecords.Records.Select(r =>
            {
                var d = JsonSerializer.Deserialize<Dictionary<string, JsonElement>>(r.DataJson) ?? new();
                var label = d.TryGetValue(displayField, out var v) ? v.ToString() : r.Id.ToString();
                return new ParentOption { Id = r.Id, Label = label };
            }).ToList();
        }

        if (!_isNew)
        {
            var record = await RecordService.GetByIdAsync(EntityId, RecordId!.Value);
            if (record is not null)
            {
                _data = JsonSerializer.Deserialize<Dictionary<string, object?>>(record.DataJson) ?? new();
            }

            // Load links
            var links = await RecordService.GetLinksAsync(EntityId, RecordId!.Value);

            foreach (var rel in _parentRelationships)
            {
                var link = links.FirstOrDefault(l => l.RelationshipId == rel.Id && l.Direction == "incoming");
                _parentValues[rel.Id] = link?.SourceRecordId.ToString();
                _originalParentValues[rel.Id] = link?.SourceRecordId.ToString();
                _parentLinkIds[rel.Id] = link?.Id;
            }

            foreach (var rel in _childRelationships)
            {
                await LoadChildSection(rel);
            }
        }
    }

    private string GetValue(string fieldName)
    {
        if (_data.TryGetValue(fieldName, out var val) && val is not null)
        {
            if (val is JsonElement je) return je.ValueKind == JsonValueKind.Null ? "" : je.ToString();
            return val.ToString() ?? "";
        }
        return "";
    }

    private bool GetBoolValue(string fieldName)
    {
        var v = GetValue(fieldName);
        return v.Equals("true", StringComparison.OrdinalIgnoreCase) || v == "True";
    }

    private void SetValue(string fieldName, object? value) => _data[fieldName] = value;

    private string GetParentValue(Guid relId) => _parentValues.TryGetValue(relId, out var v) ? v ?? "" : "";
    private void SetParentValue(Guid relId, string? value) => _parentValues[relId] = value;

    private List<string> GetOptions(FieldDefinition field)
    {
        if (string.IsNullOrEmpty(field.OptionsJson)) return new();
        return JsonSerializer.Deserialize<List<string>>(field.OptionsJson) ?? new();
    }

    private string GetInputType(FieldDataType type) => type switch
    {
        FieldDataType.Email => "email",
        FieldDataType.Phone => "tel",
        FieldDataType.Url => "url",
        _ => "text"
    };

    private async Task Save()
    {
        _saving = true;
        _error = null;
        try
        {
            var json = JsonSerializer.Serialize(_data);

            if (_isNew)
            {
                var created = await RecordService.CreateAsync(EntityId, json);
                foreach (var (relId, parentId) in _parentValues)
                {
                    if (Guid.TryParse(parentId, out var pid))
                    {
                        await RecordService.CreateLinkAsync(pid, relId, created.Id);
                    }
                }
                Nav.NavigateTo($"records/{EntityId}");
            }
            else
            {
                await RecordService.UpdateAsync(EntityId, RecordId!.Value, json);
                await SaveParentLinks();
                Nav.NavigateTo($"records/{EntityId}");
            }
        }
        catch (Exception ex) { _error = ex.Message; }
        finally { _saving = false; }
    }

    private async Task SaveParentLinks()
    {
        foreach (var rel in _parentRelationships)
        {
            var oldVal = _originalParentValues.GetValueOrDefault(rel.Id);
            var newVal = _parentValues.GetValueOrDefault(rel.Id);

            if (oldVal == newVal) continue;

            // Remove existing link if there was one
            if (_parentLinkIds.TryGetValue(rel.Id, out var linkId) && linkId.HasValue)
            {
                await RecordService.DeleteLinkAsync(linkId.Value);
            }

            // Create new link if a parent is selected
            if (Guid.TryParse(newVal, out var newParentId))
            {
                await RecordService.CreateLinkAsync(newParentId, rel.Id, RecordId!.Value);
            }
        }
    }

    private void GoBack() => Nav.NavigateTo($"records/{EntityId}");

    private void NavigateToParent(RelationshipDefinition rel)
    {
        if (_parentValues.TryGetValue(rel.Id, out var parentId) && Guid.TryParse(parentId, out var pid))
        {
            Nav.NavigateTo($"records/{rel.SourceEntityId}/{pid}");
        }
    }

    private string GetChildCellValue(string dataJson, string fieldName)
    {
        try
        {
            using var doc = JsonDocument.Parse(dataJson);
            if (doc.RootElement.TryGetProperty(fieldName, out var val))
                return val.ValueKind == JsonValueKind.Null ? "" : val.ToString();
        }
        catch { }
        return "";
    }

    private async Task LoadChildSection(RelationshipDefinition rel)
    {
        var entity = await EntityService.GetByIdAsync(rel.TargetEntityId);
        var fields = entity?.Fields?.OrderBy(f => f.SortOrder).ToList() ?? new();
        var links = await RecordService.GetLinksAsync(EntityId, RecordId!.Value);
        var childLinks = links.Where(l => l.RelationshipId == rel.Id && l.Direction == "outgoing").ToList();
        var records = new List<Record>();
        foreach (var cl in childLinks)
        {
            var rec = await RecordService.GetByIdAsync(rel.TargetEntityId, cl.TargetRecordId);
            if (rec is not null) records.Add(rec);
        }
        _childSections[rel.Id] = new ChildSection
        {
            Entity = entity!,
            Fields = fields,
            Records = records
        };
    }

    private void StartAddChild(Guid relId)
    {
        _editingChildRelId = relId;
        _editingChildId = null;
        _childEditData = new();
        _childEditError = null;
    }

    private void StartEditChild(Guid relId, Record rec)
    {
        _editingChildRelId = relId;
        _editingChildId = rec.Id;
        _childEditData = JsonSerializer.Deserialize<Dictionary<string, object?>>(rec.DataJson) ?? new();
        _childEditError = null;
    }

    private void CancelChildEdit()
    {
        _editingChildRelId = null;
        _editingChildId = null;
        _childEditData = new();
        _childEditError = null;
    }

    private string GetChildEditValue(string fieldName)
    {
        if (_childEditData.TryGetValue(fieldName, out var val) && val is not null)
        {
            if (val is JsonElement je) return je.ValueKind == JsonValueKind.Null ? "" : je.ToString();
            return val.ToString() ?? "";
        }
        return "";
    }

    private bool GetChildEditBool(string fieldName) =>
        GetChildEditValue(fieldName).Equals("true", StringComparison.OrdinalIgnoreCase);

    private void SetChildEditValue(string fieldName, object? value) => _childEditData[fieldName] = value;

    private async Task SaveChild(Guid relId)
    {
        _childEditError = null;
        try
        {
            var rel = _childRelationships.First(r => r.Id == relId);
            var json = JsonSerializer.Serialize(_childEditData);

            if (_editingChildId is null)
            {
                // Create new child and link to parent
                var created = await RecordService.CreateAsync(rel.TargetEntityId, json);
                await RecordService.CreateLinkAsync(RecordId!.Value, relId, created.Id);
            }
            else
            {
                await RecordService.UpdateAsync(rel.TargetEntityId, _editingChildId.Value, json);
            }

            CancelChildEdit();
            await LoadChildSection(rel);
        }
        catch (Exception ex) { _childEditError = ex.Message; }
    }

    private async Task DeleteChild(Guid relId, Guid childRecordId)
    {
        try
        {
            var rel = _childRelationships.First(r => r.Id == relId);
            // Delete the link first, then the record
            var links = await RecordService.GetLinksAsync(EntityId, RecordId!.Value);
            var link = links.FirstOrDefault(l => l.RelationshipId == relId && l.TargetRecordId == childRecordId);
            if (link is not null) await RecordService.DeleteLinkAsync(link.Id);
            await RecordService.DeleteAsync(rel.TargetEntityId, childRecordId);
            await LoadChildSection(rel);
        }
        catch (Exception ex) { _error = ex.Message; }
    }

    private class ParentOption { public Guid Id { get; set; } public string Label { get; set; } = ""; }
    private class ChildSection
    {
        public EntityDefinition Entity { get; set; } = null!;
        public List<FieldDefinition> Fields { get; set; } = new();
        public List<Record> Records { get; set; } = new();
    }
}
